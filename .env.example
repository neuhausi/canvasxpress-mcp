# CanvasXpress MCP Server — environment configuration template
# Copy to .env and fill in your values.

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
MCP_HOST=0.0.0.0
MCP_PORT=8100

# Comma-separated origins allowed by CORS.  Use * for fully public APIs.
CORS_ORIGINS=http://localhost:8100,http://127.0.0.1:8100

# 1 = verbose per-request debug trace on stderr
CX_DEBUG=0

# ---------------------------------------------------------------------------
# LLM provider  (anthropic | bedrock | ollama | openai)
# ---------------------------------------------------------------------------
LLM_PROVIDER=anthropic
# LLM_MODEL=claude-opus-4-20250514

# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- Amazon Bedrock ---
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# AWS_PROFILE=

# --- Ollama ---
# OLLAMA_BASE_URL=http://localhost:11434

# --- OpenAI / gateway ---
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_ORG=

# ---------------------------------------------------------------------------
# Knowledge / schema
# ---------------------------------------------------------------------------
CX_SCHEMA_TTL=3600
CX_SKIP_FETCH=0
EMBEDDING_MODEL=all-MiniLM-L6-v2
