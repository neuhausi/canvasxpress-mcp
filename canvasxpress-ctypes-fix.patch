+def load_libsqlite():
+    """Load libsqlite3 shared library via ctypes."""
+    for lib_path in [
+        "/usr/lib64/libsqlite3.so.0",
+        "/usr/lib64/libsqlite3.so",
+        "/usr/lib/libsqlite3.so.0",
+        "/usr/lib/x86_64-linux-gnu/libsqlite3.so.0",
+        ctypes.util.find_library("sqlite3"),
+    ]:
+        if lib_path is None:
+            continue
+        try:
+            lib = ctypes.CDLL(lib_path)
+            _ = lib.sqlite3_enable_load_extension
+            print(f"  Loaded libsqlite3 from: {lib_path}")
+            return lib
+        except (OSError, AttributeError):
+            continue
+    raise RuntimeError("Could not load libsqlite3. Cannot enable extensions.")
