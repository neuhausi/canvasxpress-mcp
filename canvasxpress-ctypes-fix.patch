+class ExtensionConnection:
+    """
+    Wrapper around sqlite3.Connection that adds load_extension support
+    via ctypes when Python was compiled without --enable-loadable-sqlite-extensions.
+    Delegates all other attribute access to the real connection.
+    """
+ 
+    def __init__(self, db_path: str, libsqlite):
+        self._db = sqlite3.connect(db_path)
+        self._lib = libsqlite
+        self._db_ptr = self._find_db_ptr()
+        self._enable_extensions()
+ 
+    def _find_db_ptr(self):
+        self._lib.sqlite3_db_filename.argtypes = [ctypes.c_void_p, ctypes.c_char_p]
+        self._lib.sqlite3_db_filename.restype = ctypes.c_char_p
+ 
+        base = id(self._db)
+        # Offset 16 confirmed for CPython 3.12 on this system via diagnostic scan
+        candidate = ctypes.c_void_p.from_address(base + 16).value
+        if not candidate:
+            raise RuntimeError("sqlite3* handle at offset 16 is null.")
+        filename = self._lib.sqlite3_db_filename(candidate, b"main")
+        print(f"  Found sqlite3* handle, db={filename}")
+        return candidate
+ 
+    def _enable_extensions(self):
+        self._lib.sqlite3_enable_load_extension.argtypes = [ctypes.c_void_p, ctypes.c_int]
+        self._lib.sqlite3_enable_load_extension.restype = ctypes.c_int
+        rc = self._lib.sqlite3_enable_load_extension(self._db_ptr, 1)
+        if rc != 0:
+            raise RuntimeError(f"sqlite3_enable_load_extension failed with code {rc}")
+        print("  Extension loading enabled via ctypes.")
+ 
+    def load_extension(self, path):
+        self._lib.sqlite3_load_extension.argtypes = [
+            ctypes.c_void_p, ctypes.c_char_p, ctypes.c_char_p, ctypes.c_void_p
+        ]
+        self._lib.sqlite3_load_extension.restype = ctypes.c_int
+        errmsg = ctypes.c_char_p()
+        rc = self._lib.sqlite3_load_extension(
+            self._db_ptr,
+            path.encode() if isinstance(path, str) else path,
+            None,
+            ctypes.byref(errmsg)
+        )
+        if rc != 0:
+            raise RuntimeError(f"load_extension failed: {errmsg.value}")
+ 
+    def enable_load_extension(self, enabled):
+        pass  # Already handled; no-op to satisfy sqlite_vec.load()
+ 
+    def __getattr__(self, name):
+        # Delegate everything else (execute, commit, close, etc.) to real connection
+        return getattr(self._db, name)
+ 
+    def __enter__(self):
+        return self
+ 
+    def __exit__(self, *args):
+        self._db.close()
+ 
+ 
+def connect(db_path: str):
+    """
+    Return a sqlite3 connection with extension loading enabled.
+    Uses native support if available, otherwise falls back to ctypes wrapper.
+    """
+    try:
+        db = sqlite3.connect(db_path)
+        db.enable_load_extension(True)
+        print("  Extension loading enabled natively.")
+        return db
+    except AttributeError:
+        print("  Native enable_load_extension unavailable, using ctypes wrapper...")
+        libsqlite = load_libsqlite()
+        return ExtensionConnection(db_path, libsqlite)
